{
  "name": "nts-widget",
  "productName": "NTS Widget",
  "version": "1.0.0",
  "description": "Unofficial macOS menu bar widget for NTS Radio — full schedule, live info, and in-app streaming.",
  "author": "NTS Widget contributors",
  "license": "MIT",
  "private": true,
  "main": "main.js",
  "scripts": {
    "build": "esbuild renderer/app.jsx --bundle --outfile=renderer/bundle.js",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder --mac"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.23.0"
  },
  "build": {
    "appId": "com.ntswidget.app",
    "productName": "NTS Widget",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "menubar-icon.png",
      "menubar-icon@2x.png",
      "menubar-icon@3x.png"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.music",
      "target": [
        { "target": "dmg", "arch": ["arm64"] },
        { "target": "zip", "arch": ["arm64"] }
      ]
    },
    "dmg": {
      "title": "NTS Widget",
      "contents": [
        { "x": 130, "y": 220, "type": "file" },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    }
  }
}
